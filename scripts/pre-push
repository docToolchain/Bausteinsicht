#!/bin/bash
# Pre-push hook: Run duplicate detection and branch checks before pushing
# Install: make install-hooks

set -euo pipefail

echo "==> Pre-push checks..."
echo ""

# Get current branch
CURRENT_BRANCH=$(git rev-parse --abbrev-ref HEAD)

if [ "$CURRENT_BRANCH" = "main" ]; then
  echo "ℹ️  Skipping checks for main branch"
  exit 0
fi

# 1. Check if branch is based on main
echo "  Checking branch origin..."
git fetch origin 2>/dev/null || true

BASE=$(git merge-base origin/main HEAD)
MAIN_HEAD=$(git rev-parse origin/main 2>/dev/null || echo "")

if [ -z "$MAIN_HEAD" ]; then
  echo "⚠️  Could not fetch main branch info"
  exit 0
fi

if [ "$BASE" != "$MAIN_HEAD" ]; then
  BEHIND=$(git rev-list --count HEAD..origin/main)
  if [ "$BEHIND" -gt 0 ]; then
    echo "⚠️  Branch is behind main by $BEHIND commit(s)"
    echo ""
    echo "Recommendation: Rebase before pushing"
    echo "  git rebase origin/main"
    echo "  git push --force-with-lease"
    echo ""
    read -p "Continue push anyway? (y/n) " -n 1 -r
    echo
    if [[ ! $REPLY =~ ^[Yy]$ ]]; then
      exit 1
    fi
  fi
fi

# 2. Run local duplicate check
echo "  Checking for duplicate branches..."
if command -v bash &>/dev/null; then
  bash scripts/check-duplicate-branches.sh 2>/dev/null || true
fi

echo ""
echo "==> Pre-push checks passed."
