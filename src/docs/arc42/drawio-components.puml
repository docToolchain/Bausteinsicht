@startuml
!include <C4/C4_Component>

Container(bausteinsicht_export, "Export", "Go", "Diagram export to PNG and SVG formats via draw.io CLI")
Component(bausteinsicht_sync_forward, "Forward Sync", "Go", "Applies model changes to draw.io diagrams (model → drawio)")
System_Ext(drawio_app, "draw.io App", "draw.io desktop or web application for visual diagram editing")
Container_Boundary(bausteinsicht_drawio, "draw.io") {
  Component(bausteinsicht_drawio_connector, "Connector", "Go", "Connector/relationship CRUD for edges between elements")
  Component(bausteinsicht_drawio_document, "Document", "Go", "XML parsing, page management, and file I/O for .drawio files")
  Component(bausteinsicht_drawio_element, "Element", "Go", "Element CRUD operations on mxGraphModel objects and mxCells")
  Component(bausteinsicht_drawio_label, "Label", "Go", "HTML label generation and parsing for element display text")
  Component(bausteinsicht_drawio_template, "Template", "Go", "Template loading and style lookup from .drawio template files")
}

Rel(drawio_app, bausteinsicht_drawio_document, "modifies .drawio file")
Rel(bausteinsicht_sync_forward, bausteinsicht_drawio_element, "creates/updates elements")
Rel(bausteinsicht_sync_forward, bausteinsicht_drawio_connector, "creates/updates connectors")
Rel(bausteinsicht_drawio_element, bausteinsicht_drawio_label, "generates labels")
Rel(bausteinsicht_drawio_element, bausteinsicht_drawio_template, "looks up styles")
Rel(bausteinsicht_drawio_element, bausteinsicht_drawio_document, "modifies pages")
Rel(bausteinsicht_drawio_connector, bausteinsicht_drawio_document, "modifies pages")
Rel(bausteinsicht_export, bausteinsicht_drawio_document, "reads diagram pages")
@enduml
