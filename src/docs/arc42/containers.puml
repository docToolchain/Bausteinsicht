@startuml
!include <C4/C4_Container>

Person(developer, "Developer", "Developer using the Bausteinsicht CLI to manage architecture models")
System_Ext(drawio_app, "draw.io App", "draw.io desktop or web application for visual diagram editing")
System_Ext(ide, "IDE", "IDE with JSON Schema support for JSONC editing with autocompletion")
System_Boundary(bausteinsicht, "Bausteinsicht") {
  Container(bausteinsicht_cli, "CLI", "Go / Cobra", "Command-line interface providing validate, sync, export, and watch commands")
  Container(bausteinsicht_drawio, "draw.io", "Go / etree", "draw.io XML document handling — elements, connectors, templates, and labels")
  Container(bausteinsicht_export, "Export", "Go", "Diagram export to PNG and SVG formats via draw.io CLI")
  Container(bausteinsicht_model, "Model", "Go", "JSONC architecture model management — loading, validation, and mutation")
  Container(bausteinsicht_sync, "Sync Engine", "Go", "Bidirectional synchronization engine between JSONC model and draw.io diagrams")
  Container(bausteinsicht_watcher, "Watcher", "Go / fsnotify", "File system monitoring for automatic sync on model or diagram changes")
}

Rel(developer, bausteinsicht_cli, "runs commands")
Rel(developer, ide, "edits JSONC")
Rel(developer, drawio_app, "edits diagrams")
Rel(ide, bausteinsicht_model, "JSON Schema validation")
Rel(drawio_app, bausteinsicht_drawio, "modifies .drawio file")
Rel(bausteinsicht_cli, bausteinsicht_model, "loads/saves JSONC")
Rel(bausteinsicht_cli, bausteinsicht_sync, "triggers sync")
Rel(bausteinsicht_cli, bausteinsicht_watcher, "starts watch mode")
Rel(bausteinsicht_cli, bausteinsicht_export, "triggers export")
Rel(bausteinsicht_sync, bausteinsicht_drawio, "creates/updates elements")
Rel(bausteinsicht_sync, bausteinsicht_model, "comment-preserving updates")
Rel(bausteinsicht_watcher, bausteinsicht_sync, "triggers on file change")
Rel(bausteinsicht_export, bausteinsicht_drawio, "reads diagram pages")
@enduml
